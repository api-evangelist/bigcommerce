{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MeasurementUnitsSettings",
  "title": "MeasurementUnitsSettings",
  "type": "object",
  "properties": {
    "weight_measurement": {
      "type": "string",
      "example": "Ounces",
      "enum": [
        "LBS",
        "Ounces",
        "KGS",
        "Grams",
        "Tonnes"
      ]
    },
    "length_measurement": {
      "type": "string",
      "example": "Inches",
      "enum": [
        "Inches",
        "Centimeters"
      ]
    },
    "decimal_token": {
      "type": "string",
      "example": "."
    },
    "thousands_token": {
      "type": "string",
      "example": ","
    },
    "decimal_places": {
      "type": "integer",
      "example": 2
    },
    "factoring_dimension": {
      "type": "string",
      "example": "depth",
      "enum": [
        "depth",
        "height",
        "width"
      ]
    }
  }
}