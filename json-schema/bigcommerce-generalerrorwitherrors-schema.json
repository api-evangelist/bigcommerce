{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GeneralErrorWithErrors",
  "title": "Error Response",
  "required": [
    "status",
    "title",
    "type",
    "errors"
  ],
  "type": "object",
  "properties": {
    "status": {
      "type": "integer",
