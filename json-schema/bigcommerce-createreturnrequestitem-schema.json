    "quantity": {
      "type": "integer",
      "minimum": 1
    },
    "preferred_outcome_id": {
      "type": "integer",
      "format": "int64"
    },
    "reason_id": {
      "type": "integer",
      "format": "int64"
    }
  },
  "x-internal": false
}