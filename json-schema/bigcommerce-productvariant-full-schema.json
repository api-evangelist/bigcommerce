      "depth": 0,
      "is_free_shipping": true,
      "fixed_cost_shipping_price": 0,
      "purchasing_disabled": true,
      "purchasing_disabled_message": "string",
      "upc": "string",
      "inventory_level": 0,
      "inventory_warning_level": 0,
      "bin_picking_number": "string",
      "mpn": "string",
      "gtin": "012345678905",
      "id": 0,
      "product_id": 0,
      "sku": "string",
      "sku_id": 0,
      "option_values": [
        {
          "option_display_name": "Color",
          "label": "Beige",
          "id": 146,
          "option_id": 151
        }
      ],
      "calculated_price": 0,
      "calculated_weight": 0
    }
  }
}