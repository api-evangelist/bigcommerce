{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CustomTemplateAssociationUpsert",
  "title": "CustomTemplateAssociation",
  "type": "object",
  "properties": {
    "channel_id": {
      "type": "integer"
    },
    "entity_type": {
      "type": "string",
      "enum": [
        "product",
        "category",
        "brand",
        "page"
      ]
    },
    "entity_id": {
      "type": "integer"
    },
    "file_name": {
      "type": "string",
      "example": "custom-product-1.html"
    }
  },
  "required": [
    "channel_id",
    "entity_type",
    "entity_id",
    "file_name"
  ],
  "x-internal": false
}