{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DimensionValue",
  "title": "Dimension Value",
  "description": "Value object for a length measurement.",
  "type": "object",
  "properties": {
    "units": {
      "type": "string",
      "enum": [
        "cm",
        "in"
      ]
    },
    "value": {
      "type": "number",
      "minimum": 0
    }
  },
  "required": [
    "units",
    "value"
  ],
  "x-internal": false
}