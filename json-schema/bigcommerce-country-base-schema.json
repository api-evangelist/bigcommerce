{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/country_Base",
  "title": "country_Base",
  "type": "object",
  "properties": {
    "country": {
      "type": "string",
      "example": "Australia",
      "description": "Country name."
    },
    "country_iso2": {
      "type": "string",
      "description": "2-letter country code.",
      "example": "AU"
    },
    "country_iso3": {
      "type": "string",
      "description": "3-letter country code.",
      "example": "AUS"
    }
  },
  "x-internal": false
}