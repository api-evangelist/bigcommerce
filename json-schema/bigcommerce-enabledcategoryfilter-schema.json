{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/EnabledCategoryFilter",
  "title": "EnabledCategoryFilter",
  "description": "A storefront filter for product category",
  "type": "object",
  "properties": {
    "collapsed_by_default": {
      "type": "boolean"
    },
    "display_name": {
      "type": "string"
    },
    "display_product_count": {
      "type": "boolean"
    },
    "id": {
      "type": "string"
    },
    "is_enabled": {
      "type": "boolean"
    },
    "items_to_show": {
      "type": "integer",
      "enum": [
        5,
        10,
        15
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "category"
      ]
    }
  },
  "x-internal": false
}