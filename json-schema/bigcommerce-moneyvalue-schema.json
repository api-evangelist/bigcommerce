{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MoneyValue",
  "title": "Money Value",
  "description": "Value object for a money amount.",
  "type": "object",
  "properties": {
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3,3}$"
    },
    "amount": {
      "type": "number",
      "minimum": 0
    }
  },
  "required": [
    "currency",
    "amount"
  ],
  "x-internal": false
}