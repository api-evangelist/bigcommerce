{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/RedirectTo",
  "title": "RedirectTo",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "product",
        "brand",
        "category",
        "page",
        "post",
        "url"
      ]
    },
    "entity_id": {
      "type": "integer"
    },
    "url": {
      "maxLength": 2048,
      "type": "string",
      "example": "/new-url/"
    }
  }
}