{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SystemLog",
  "title": "SystemLog",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "type": {
      "type": "string"
    },
    "module": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "date_created": {
      "type": "string",
      "format": "date-time"
    }
  }
}