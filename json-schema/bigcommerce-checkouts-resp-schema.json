                        },
                        "extendedSalePrice": {
                          "type": "number",
                          "description": "The item\u02bcs sale price multiplied by the quantity.",
                          "format": "double"
                        },
                        "type": {
                          "type": "string",
                          "description": "the product type - physical or digital"
                        },
                        "isMutable": {
                          "type": "boolean",
                          "description": ""
                        },
                        "isShippingRequired": {
                          "type": "boolean",
                          "description": "Whether this item requires shipping to a physical address."
