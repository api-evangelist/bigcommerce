                        },
                        "isShippingRequired": {
                          "type": "boolean",
                          "description": "Whether this item requires shipping to a physical address."
                        },
                        "isMutable": {
                          "type": "boolean",
                          "description": ""
                        },
                        "giftWrapping": {
