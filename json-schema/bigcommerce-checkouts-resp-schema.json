                            "name": {
                              "type": "string",
                              "description": ""
                            },
                            "message": {
                              "type": "string",
                              "description": ""
                            },
                            "amount": {
                              "type": "number",
                              "description": "",
                              "format": "double"
                            }
                          }
                        }
                      }
                    }
