                          }
                        },
                        "recipient": {
                          "title": "Contact Entity",
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string",
                              "description": ""
                            },
                            "email": {
                              "type": "string",
                              "description": ""
                            }
                          }
                        },
                        "message": {
                          "type": "string",
                          "description": "Limited to 200 characters."
                        },
                        "type": {
                          "type": "string",
                          "description": "Explicitly specifying the gift certificate type."
                        }
