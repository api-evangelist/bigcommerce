{
    "openapi": "3.0.0",
    "info": {
        "version": "",
        "title": "Wishlist API",
        "description": "## Wishlist API\n  \nThe Wishlist API allows a developer to create and manage customer [Wishlists](https:\/\/support.bigcommerce.com\/s\/article\/Wishlists). A Wishlist allows you to see what your customers are interested in and saving on the store. With this information you\u2019ll be able to create targeted campaigns to help merchants grow their business.\u00a0 ",
        "termsOfService": "http:\/\/exmple.com\/license\/"
    },
    "servers": [
        "http:\/\/api.bigcommerce.com\/stores\/{store_hash}\/v3"
    ],
    "paths": {
        "\/wishlists": {
            "post": {
                "summary": "Create a Wishlist",
                "description": "Creates a [*Wishlist*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlist) and [*Wishlist Item*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlistitem). More than one item can be added in the POST.\n\n**Required Fields**\n* name\n* customer_id",
                "operationId": "WishlistsPost",
                "deprecated": 0,
                "parameters": [],
                "responses": {
                    "201": {
                        "description": ""
                    }
                }
            },
            "get": {
                "summary": "Get All Wishlists",
                "description": "Returns a list of [*Wishlists*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlist). Optional filter parameters can be passed in.",
                "operationId": "WishlistsGet",
                "deprecated": 0,
                "parameters": [
                    {
                        "name": "customer_id",
                        "in": "query",
                        "description": "All wishlists relating to the customer."
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "The page number of results per page. 1 is the default and starts from record 0."
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "The numbers of items to return per page. Default is 50 and maximum is 250."
                    }
                ],
                "responses": {
                    "200": {
                        "description": ""
                    }
                }
            }
        },
        "\/wishlists\/{wishlist_id}\/items\/{item_id}": {
            "delete": {
                "summary": "Delete Wishlist Item",
                "description": "Deletes a [*Wishlist Item*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlistitem).",
                "operationId": "WishlistsItemsByIdDelete",
                "deprecated": 0,
                "parameters": [
                    {
                        "name": "wishlist_id",
                        "in": "path",
                        "description": "ID of the Wishlist"
                    },
                    {
                        "name": "item_id",
                        "in": "path",
                        "description": ""
                    }
                ],
                "responses": {
                    "200": {
                        "description": ""
                    }
                }
            },
            "parameters": {
                "summary": "",
                "description": "",
                "operationId": "",
                "deprecated": 0,
                "parameters": []
            }
        },
        "\/wishlists\/{wishlist_id}": {
            "get": {
                "summary": "Get a Wishlist",
                "description": "Returns a single [*Wishlist*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlist).",
                "operationId": "WishlistsByIdGet",
                "deprecated": 0,
                "parameters": [
