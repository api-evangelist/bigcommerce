            "put": {
                "summary": "Update a Wishlist",
                "description": "Updates a [*Wishlist*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlist).\n\nUse this endpoint to update an existing wishlist items, change the wishlist name, customer ID or if the wishlist is available publicly.\n\n**Required Fields**\n* customer_id",
                "operationId": "WishlistsByIdPut",
                "deprecated": 0,
                "parameters": [
                    {
                        "name": "wishlist_id",
                        "in": "path",
                        "description": "ID of the Wishlist"
                    }
                ],
                "responses": {
                    "201": {
                        "description": ""
                    }
                }
            },
            "delete": {
                "summary": "Delete a Wishlist",
                "description": "Deletes a [*Wishlist*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlist).",
                "operationId": "WishlistsByIdDelete",
                "deprecated": 0,
                "parameters": [
                    {
                        "name": "wishlist_id",
                        "in": "path",
                        "description": "ID of the Wishlist"
                    }
                ],
                "responses": {
                    "204": {
                        "description": ""
                    }
                }
            },
            "parameters": {
                "summary": "",
                "description": "",
                "operationId": "",
                "deprecated": 0,
                "parameters": []
            }
        },
        "\/wishlists\/{wishlist_id}\/items": {
            "parameters": {
                "summary": "",
                "description": "",
                "operationId": "",
                "deprecated": 0,
                "parameters": []
            },
            "post": {
                "summary": "Add Wishlist Item",
                "description": "Adds a [*Wishlist Item*](\/api-reference\/customer-subscribers\/wishlist-api\/models\/wishlistitem). More than one item can be added at a time.",
                "operationId": "WishlistsItemsByIdPost",
                "deprecated": 0,
                "parameters": [
                    {
                        "name": "wishlist_id",
                        "in": "path",
                        "description": "ID of the Wishlist"
                    }
                ],
                "responses": {
                    "201": {
                        "description": ""
                    }
                }
            }
        }
    },
